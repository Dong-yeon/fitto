# 백엔드 환경변수 예시 — 실제 값으로 복사해 사용 (export 또는 IDE Run Config)
# docker-compose.yml 기본값 기준

DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitto
DB_USERNAME=fitto
DB_PASSWORD=fitto

REDIS_HOST=localhost
REDIS_PORT=6379

# 운영에서는 반드시 안전한 무작위 값으로 교체 (미설정 시 dev 전용 기본값 사용)
JWT_SECRET=local-dev-secret-change-me-please-0123456789
