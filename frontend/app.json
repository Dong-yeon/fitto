{
  "expo": {
    "name": "Fitto",
    "slug": "fitto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fitto",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "채팅에서 사진을 공유하기 위해 사진 접근 권한이 필요해요."
        }
      ]
    ],
    "splash": {
      "backgroundColor": "#FF7A93"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitto.app"
    },
    "android": {
      "package": "com.fitto.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF7A93",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Fitto",
      "shortName": "Fitto",
      "lang": "ko",
      "themeColor": "#FF7A93",
      "backgroundColor": "#FFF9FA",
      "display": "standalone",
      "description": "커플 운동 채팅 앱 — 함께라서 더 건강해"
    }
  }
}
